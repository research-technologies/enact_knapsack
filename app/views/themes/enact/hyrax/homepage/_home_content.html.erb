<%# Enact theme homepage. Editorial landing rather than tabbed cards. %>
<%# Mirrors the prototype's Browse hero (eyebrow, italic headline, lede, %>
<%# search bar) without embedding the catalog's facets+grid - those live %>
<%# on the catalog page itself (Slice C will theme that). %>

<% portfolio_count = (@recent_documents&.size || 0) %>

<div class="enact-home">
  <section class="enact-home__hero">
    <div class="enact-eyebrow">
      National repository
      <% if portfolio_count > 0 %>
        · <%= number_with_delimiter(portfolio_count) %> deposits visible to you
      <% end %>
    </div>
    <h1 class="enact-home__headline">
      <%= block_for(name: 'marketing').presence || 'A national repository for UK practice research.' %>
    </h1>
    <% if display_content_block? @home_text %>
      <div class="enact-home__lede">
        <%= displayable_content_block @home_text %>
      </div>
    <% else %>
      <p class="enact-home__lede">
        Each portfolio holds a researcher's account of their creative practice - performances, scores, fieldwork, writing - gathered as a single narrative rather than catalogued in isolation.
      </p>
    <% end %>
    <div class="enact-home__actions">
      <a class="btn btn-primary" href="<%= main_app.search_catalog_path %>">Browse the archive</a>
      <% if user_signed_in? %>
        <a class="btn btn-secondary" href="<%= main_app.hyrax_my_works_path rescue main_app.root_path %>">Deposit a portfolio</a>
      <% end %>
    </div>

    <%# Hero search bar - submits to the catalog page, matching the prototype's
        "Search titles, contributors, keywords..." input. %>
    <%= form_tag main_app.search_catalog_path, method: :get, class: 'enact-home__search' do %>
      <span class="enact-home__search-icon" aria-hidden="true">⌕</span>
      <%= text_field_tag :q, params[:q], placeholder: 'Search titles, contributors, keywords...', class: 'enact-home__search-input', 'aria-label': 'Search the archive' %>
      <%= hidden_field_tag :search_field, 'all_fields' %>
      <button type="submit" class="enact-home__search-submit">Search</button>
    <% end %>
  </section>

  <% if @presenter.display_recently_uploaded? && @recent_documents.present? %>
    <section class="enact-home__section">
      <div class="enact-section-rule">
        <span class="label">Recently deposited</span>
        <span class="count">· <%= @recent_documents.size %></span>
        <span class="rule"></span>
        <a href="<%= main_app.search_catalog_path %>" class="enact-home__see-all">See all →</a>
      </div>
      <div class="enact-home__grid">
        <% @recent_documents.first(6).each do |doc| %>
          <%= link_to main_app.solr_document_path(doc), class: 'enact-card' do %>
            <div class="enact-card__media">
              <% if doc.thumbnail_path %>
                <%= image_tag doc.thumbnail_path, alt: '', class: 'enact-card__thumb' %>
              <% end %>
            </div>
            <div class="enact-card__body">
              <div class="enact-card__eyebrow"><%= doc.human_readable_type %></div>
              <h3 class="enact-card__title"><%= doc.title.is_a?(Array) ? doc.title.first : doc.title %></h3>
              <% if doc.creator.present? %>
                <p class="enact-card__meta"><%= Array(doc.creator).join(', ') %></p>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <% collections = (@presenter.featured_collections.first(4) rescue []) %>
  <% if collections.any? %>
    <section class="enact-home__section">
      <div class="enact-section-rule">
        <span class="label">Featured collections</span>
        <span class="rule"></span>
      </div>
      <div class="enact-home__grid">
        <% collections.each do |coll| %>
          <%= link_to main_app.hyrax_collection_path(coll.id), class: 'enact-card' do %>
            <div class="enact-card__media"></div>
            <div class="enact-card__body">
              <div class="enact-card__eyebrow">Collection</div>
              <h3 class="enact-card__title"><%= coll.title.is_a?(Array) ? coll.title.first : coll.title %></h3>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="enact-home__pathfinders">
    <div class="enact-section-rule">
      <span class="label">Pathfinder partners</span>
      <span class="rule"></span>
    </div>
    <p class="enact-home__pathfinders-copy">
      Enact is developed with five pathfinder partner institutions whose researchers shape what the platform becomes. It runs on <a href="https://hyku.samvera.org">Hyku</a>, an open-source repository platform.
    </p>
  </section>
</div>
