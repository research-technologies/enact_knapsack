<%# OVERRIDE Hyku v7.1.0 (institutional_repository theme): "Browse by Collection" -> "Browse by User Collection" %>
<%# to disambiguate from the PortfolioItemCollection work type. %>
<h2>Browse by User Collection</h2>
<% @top_level_collections.each do |collection| %>
  <div class="col-12">
    <div>
      <ul class="list-unstyled all-collection-list">
        <%= link_to [hyrax, collection] do %>
          <li><%= collection.title_or_label %></li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
