<%# Contributor profile page: a profile header (name, type badge, ORCID icon,
    affiliations) over a "Works" section listing the works crediting this
    contributor (access-scoped to the viewer), with each credit's roles shown as
    badges. The claimed/unclaimed indicator and claim CTA come later. %>
<div class="container enact-contributor-show">
  <header class="enact-contributor-header mb-4">
    <div class="d-flex justify-content-between align-items-start">
      <h1 class="mb-2"><%= @contributor.display_name %></h1>
      <div class="enact-contributor-actions">
        <%# Opens the research-network map centred on this person: their direct
            (first-order) collaborators, plus who is one step further out. %>
        <%# turbolinks/turbo false: /people-map is a standalone (layout:false) page,
            so it must load as a full request, not be swapped in by Turbolinks
            (which leaves Cytoscape half-initialised until a hard refresh). Same
            as the relationship-map button. %>
        <%= link_to t('enact.people_map.profile_link', default: 'Research network'),
                    "/people-map?focus=#{@contributor.id}",
                    class: 'btn btn-outline-primary btn-sm',
                    data: { turbolinks: false, turbo: false } %>
        <%# Edit is admin-gated in the controller; only surface the link to admins. %>
        <% if current_ability.admin? %>
          <%= link_to t('enact.contributors.edit.link', default: 'Edit'),
                      "/contributors/#{@contributor.id}/edit",
                      class: 'btn btn-outline-secondary btn-sm ml-1' %>
        <% end %>
      </div>
    </div>

    <div class="enact-contributor-identity text-muted">
      <span class="badge badge-secondary enact-contributor-type">
        <%= t("enact.contributors.types.#{@contributor.agent_type}", default: @contributor.agent_type.humanize) %>
      </span>
      <% if @contributor.orcid.present? %>
        <%= link_to @contributor.orcid, class: 'enact-contributor-orcid ml-1', target: '_blank',
                    rel: 'noopener', title: @contributor.orcid do %>
          <%= image_tag 'orcid.png', alt: t('enact.contributors.orcid'), width: 16, height: 16,
                        class: 'enact-orcid-icon' %>
        <% end %>
      <% end %>
      <%# General name identifiers (ISNI/VIAF/ROR/…), multi-valued, distinct from ORCID. %>
      <% @contributor.name_identifiers.each do |ident| %>
        <span class="enact-contributor-identifier ml-2">
          <% if ident['scheme'].present? %>
            <span class="enact-contributor-identifier-scheme"><%= ident['scheme'] %>:</span>
          <% end %>
          <%= ident['value'] %>
        </span>
      <% end %>
    </div>

    <% if @contributor.affiliations.present? %>
      <ul class="list-inline enact-contributor-affiliations text-muted mt-2 mb-0">
        <% @contributor.affiliations.each do |affiliation| %>
          <li class="list-inline-item"><%= affiliation %></li>
        <% end %>
      </ul>
    <% end %>
  </header>

  <section class="enact-contributor-works">
    <%# Title search + work-type filter over the credited-works list, mirroring
        the browse index. GET so it is bookmarkable and paginates cleanly. Only
        shown when the contributor has works to search (regardless of the current
        filter, so a filter that matches nothing can still be reset). %>
    <% if @has_works %>
      <%= form_with url: "/contributors/#{@contributor.id}", method: :get, class: 'enact-contributor-works-search mb-4' do %>
        <div class="form-row align-items-end">
          <div class="col-md-6 mb-2">
            <%= label_tag :q, t('enact.contributors.works.search_label', default: 'Search works'), class: 'form-label small text-muted' %>
            <%= search_field_tag :q, @search,
                                 placeholder: t('enact.contributors.works.search_placeholder', default: 'Search works by title'),
                                 class: 'form-control' %>
          </div>
          <div class="col-md-3 mb-2">
            <%= label_tag :work_type, t('enact.contributors.works.type_label', default: 'Type'), class: 'form-label small text-muted' %>
            <%= select_tag :work_type,
                           options_for_select(@work_type_options, @work_type),
                           class: 'form-control' %>
          </div>
          <div class="col-md-3 mb-2">
            <%= submit_tag t('enact.contributors.works.search_submit', default: 'Search'), class: 'btn btn-primary' %>
            <%# Reset clears every filter by linking to the bare profile. Shown
                only when a search term or type filter is active. %>
            <% if @search.present? || @work_type %>
              <%= link_to t('enact.contributors.works.reset', default: 'Reset'),
                          "/contributors/#{@contributor.id}", class: 'btn btn-outline-secondary ml-1' %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if @works.present? %>
      <%# Range + total so the user knows how many works there are and where they
          are in the paged set. total_count reflects the active filter. %>
      <% first = @works.offset_value + 1 %>
      <p class="text-muted small enact-contributor-works-count">
        <%= t('enact.contributors.works.count',
              count: @works.total_count, first:, last: @works.offset_value + @works.size,
              total: @works.total_count) %>
      </p>
      <ul class="list-unstyled">
        <% @works.each do |work| %>
          <li class="enact-contributor-work d-flex align-items-start mb-3">
            <% if work.thumbnail.present? %>
              <%= link_to(work.path || '#', class: 'enact-contributor-work-thumb mr-3', tabindex: -1, 'aria-hidden': true) do %>
                <%= image_tag work.thumbnail, alt: '', class: 'enact-work-thumb-img' %>
              <% end %>
            <% end %>
            <div class="enact-contributor-work-body">
              <% title = work.title.presence || t('enact.contributors.works.untitled', default: 'Untitled') %>
              <div class="enact-contributor-work-title">
                <% if work.type_label.present? %>
                  <span class="enact-contributor-work-type text-muted"><%= work.type_label %>:</span>
                <% end %>
                <%= work.path.present? ? link_to(title, work.path) : title %>
              </div>
              <% if work.roles.present? || work.role_other.present? %>
                <div class="enact-contributor-work-roles mt-1">
                  <% Array(work.roles).each do |code| %>
                    <span class="badge enact-role-badge"><%= Enact::ContributorRolesService.label(code) %></span>
                  <% end %>
                  <% Array(work.role_other).each do |role| %>
                    <span class="badge enact-role-badge"><%= role %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>

      <%# Pagination is rendered manually rather than with Kaminari's `paginate`:
          this route lives in the knapsack's isolated engine, and Kaminari resolves
          page links by string-keyed controller/action through url_for, which only
          honors symbol keys — so the engine route never matches. Building links from
          the engine path helper sidesteps that and keeps the active filters. Same
          pattern as the browse index. %>
      <% if @works.total_pages > 1 %>
        <% page_link = ->(page) { HykuKnapsack::Engine.routes.url_helpers.enact_contributor_path(@contributor.id, page: page, q: @search.presence, work_type: @work_type) } %>
        <nav aria-label="<%= t('enact.contributors.works.pagination', default: 'Works pages') %>">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= 'disabled' unless @works.prev_page %>">
              <%= link_to t('enact.contributors.works.prev_page', default: '‹ Prev'), page_link.call(@works.prev_page || 1), class: 'page-link' %>
            </li>
            <% (1..@works.total_pages).each do |page| %>
              <li class="page-item <%= 'active' if page == @works.current_page %>">
                <%= link_to page, page_link.call(page), class: 'page-link' %>
              </li>
            <% end %>
            <li class="page-item <%= 'disabled' unless @works.next_page %>">
              <%= link_to t('enact.contributors.works.next_page', default: 'Next ›'), page_link.call(@works.next_page || @works.total_pages), class: 'page-link' %>
            </li>
          </ul>
        </nav>
      <% end %>
    <% else %>
      <p class="text-muted">
        <% if @search.present? || @work_type %>
          <%= t('enact.contributors.works.no_results', default: 'No works match your search.') %>
        <% else %>
          <%= t('enact.contributors.works.empty', default: 'No works yet.') %>
        <% end %>
      </p>
    <% end %>
  </section>
</div>
