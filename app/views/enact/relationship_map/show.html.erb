<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Relationship map &mdash; Enact</title>
<%# Ported from the Hyrax prototype (wip-enact-relationship-map) into the
    knapsack as custom code. Cytoscape.js is vendored at
    app/assets/javascripts/cytoscape.js (not a CDN, not a public-volume drop).
    Data comes from PR #32's `relationships` compound via
    Enact::RelationshipMapController. The page renders with `layout: false`, so
    it pulls its own styles/scripts in here; the page-specific CSS and JS live
    in app/assets/{stylesheets,javascripts}/enact/relationship_map.* and the
    server data is handed to the JS through the JSON data island below. The
    graph builds once the container has a measured size so it renders on first
    load. %>
<%= stylesheet_link_tag 'enact/relationship_map', media: 'all' %>
<%= javascript_include_tag 'cytoscape' %>
</head>
<body>
<div id="app">
  <div id="graphwrap">
    <div id="toolbar">
      <input id="node-search" type="search" placeholder="Search works&hellip;" aria-label="Search works" autocomplete="off" />
      <span id="layoutswitch" role="group" aria-label="Layout">
        <span class="lbl">Layout</span>
        <button type="button" data-layout="cose" aria-pressed="true">Force</button>
        <button type="button" data-layout="concentric" aria-pressed="false">Radial</button>
        <button type="button" data-layout="breadthfirst" aria-pressed="false">Tree</button>
      </span>
    </div>
    <div id="cy"></div>
    <div id="empty">No related works are visible to you.</div>
    <div id="focusbar"><span>Showing how <b id="focuslabel"></b> relates</span><a id="focusclear">show all &times;</a></div>
  </div>
  <div id="side">
    <h1>Relationship map</h1>
    <div class="sub">Enact &middot; relationships (Object Handling Spec v0.2 &sect;3.5)</div>
    <div id="detail"><p class="hint">Hover a <b>node</b> to spotlight its connections; click it to focus and see details.
      Click a <b>line</b> for the relationship and its curatorial note. Drag to rearrange; scroll to zoom.</p></div>
    <div class="legend"><h2>Relationship types</h2><p class="legend-hint">Click a type to show or hide it</p><div id="rel-legend"></div></div>
    <% if @truncated %><div class="trunc">Showing the first <%= ::Enact::RelationshipMapController::MAX_WORKS %> works; some may be omitted.</div><% end %>
  </div>
</div>

<%# Server data for app/assets/javascripts/enact/relationship_map.js. Kept in a
    JSON data island so the JS stays a static, cacheable asset. %>
<script type="application/json" id="relationship-map-data">
  <%= raw({ rel_types: @rel_types, graph: @graph, focus: @focus.to_s }.to_json) %>
</script>
<%= javascript_include_tag 'enact/relationship_map' %>
</body>
</html>
