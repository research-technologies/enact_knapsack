<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Research network &mdash; Enact</title>
<%# Standalone people map: contributors linked where they share credit on a
    work, coloured by institution. Companion to the relationship map and built
    the same way - Cytoscape.js is vendored at app/assets/javascripts/cytoscape.js;
    page CSS/JS live in app/assets/{stylesheets,javascripts}/enact/people_map.*.
    Renders with `layout: false`, so it pulls its own assets here; server data
    (the contributor network from Enact::PeopleGraph, or the illustrative
    fallback) is handed to the JS through the JSON data island below.
    Precompiled in config/initializers/people_map_assets.rb. %>
<%= stylesheet_link_tag 'enact/people_map', media: 'all' %>
<%= javascript_include_tag 'cytoscape' %>
</head>
<body>
<div id="app">
  <div id="graphwrap">
    <div id="toolbar">
      <input id="search" type="search" placeholder="Search people&hellip;" aria-label="Search people" autocomplete="off" />
      <span id="layoutswitch" role="group" aria-label="Layout">
        <span class="lbl">Layout</span>
        <button type="button" data-layout="cose" aria-pressed="true">Force</button>
        <button type="button" data-layout="concentric" aria-pressed="false">Radial</button>
        <button type="button" data-layout="breadthfirst" aria-pressed="false">Tree</button>
      </span>
    </div>
    <div id="cy"></div>
    <div id="empty">No contributor network is visible to you yet.</div>
  </div>
  <div id="side">
    <h1>Research network</h1>
    <div class="sub">Enact &middot; contributors, linked where they share credit on a work</div>
    <% if @illustrative %>
      <div class="illus" role="note">Showing sample data &ndash; this repository has no linked contributors yet.</div>
    <% end %>
    <div id="detail"><p class="hint">Hover a <b>person</b> to spotlight their collaborators; click to pin their details.
      Click a <b>line</b> to see the works two people share. Drag to rearrange; scroll to zoom.</p></div>
    <div class="legend">
      <h2>Institution</h2>
      <p class="legend-hint">Click a name to show or hide it</p>
      <div id="legend"></div>
    </div>
  </div>
</div>

<%# Server data for app/assets/javascripts/enact/people_map.js. Kept in a JSON
    data island so the JS stays a static, cacheable asset. %>
<script type="application/json" id="people-data">
  <%= raw @graph.to_json %>
</script>
<%= javascript_include_tag 'enact/people_map' %>
</body>
</html>
