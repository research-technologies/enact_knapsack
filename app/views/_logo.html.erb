<%# Knapsack-level logo override. Enact wordmark when on the enact theme;
    Hyku default otherwise. %>

<% if respond_to?(:home_page_theme) && home_page_theme.to_s == 'enact' %>
  <% unless controller.controller_name == 'splash' %>
    <% if logo_image %>
      <a id="logo" class="navbar-brand enact-brand" href="<%= hyrax.root_path %>" data-no-turbolink="true">
        <%= image_tag logo_image, alt: block_for(name: 'logo_image_text') %>
      </a>
    <% else %>
      <a id="logo" class="navbar-brand enact-brand" href="<%= hyrax.root_path %>" data-no-turbolink="true" aria-label="<%= application_name %>">
        <%# The ::after pseudo-element in enact.scss appends the tagline. %>
        <span class="enact-brand__name"><%= application_name.presence || 'Enact' %></span>
      </a>
    <% end %>
  <% end %>
<% else %>
  <%# Hyku default. Kept verbatim from hyrax-webapp/app/views/_logo.html.erb. %>
  <% unless controller.controller_name == 'splash' %>
    <% if logo_image %>
      <a id="logo" href="<%= hyrax.root_path %>" data-no-turbolink="true">
        <%= image_tag logo_image, alt_text: block_for(name: 'logo_image_text') %>
      </a>
    <% else %>
      <a id="logo" class="navbar-brand" href="<%= hyrax.root_path %>" data-no-turbolink="true">
        <span class="institution_name"><%= application_name %></span>
      </a>
    <% end %>
  <% end %>
<% end %>
