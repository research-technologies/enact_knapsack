<%# OVERRIDE Hyrax 5.2.0 (samvera/hyrax main @ f9f471f): render compound metadata %>
<%# cards on the FileSet show page. Upstream file_sets/show.html.erb renders the %>
<%# show_partials + activity log but never calls render_compound_cards, so FileSet %>
<%# compounds (rights, provenance, contributors) don't display - unlike the work %>
<%# (base/show) and collection show pages, which both call it. The helper is %>
<%# dynamic (schema-derived card_compound_names), so any compound the profile %>
<%# declares with `view: { display: card }` renders with no further code. %>
<%# Tracked for upstreaming alongside the FileSet compound indexer. %>
<% provide :page_title, @presenter.page_title %>
<div class="container-fluid">
  <div class="row">
    <div class="col-12 col-sm-3">
      <%= render media_display_partial(@presenter), file_set: @presenter %>
      <%= render 'show_actions', presenter: @presenter %>
      <%= render 'single_use_links', presenter: @presenter if @presenter.editor? %>
    </div>
    <div itemscope itemtype="<%= @presenter.itemtype %>" class="col-12 col-sm-9">
      <header>
        <%= render 'file_set_title', presenter: @presenter %>
      </header>

      <% @presenter.show_partials.each do |partial_path| %>
      <%= render partial_path %>
      <% end %>

      <%= render_compound_cards(@presenter) %>

      <%= render 'hyrax/users/activity_log', events: @presenter.events %>
    </div><!-- /columns second -->
  </div> <!-- /.row -->
</div><!-- /.container-fluid -->

<%# These hidden analytics-event markers are carried over from upstream %>
<%# file_sets/show.html.erb, which leaves the spans unclosed; closed here so the %>
<%# override emits valid HTML (see PR #56 review). %>
<% @presenter.member_of_collection_ids.each do |collection_id| %>
  <span class='hide analytics-event' data-category="file-set-in-collection" data-action="file-set-in-collection-view" data-name="<%= collection_id %>" ></span>
<% end %>
<span class='hide analytics-event' data-category="file-set-in-work" data-action="file-set-in-work-view" data-name="<%= @presenter.parent.id %>" ></span>
<span class='hide analytics-event' data-category="file-set" data-action="file-set-view" data-name="<%= @presenter.id %>" ></span>
