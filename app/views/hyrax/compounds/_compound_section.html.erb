<%# Renders one compound-attribute section as a vertical stack of cards. Each
    row is a `<fieldset class="card">` whose body groups sub-fields into
    semantic clusters (Identity / Role / etc.) read from the form class's
    COMPOUND_FIELD_GROUPS constant.

    Locals:
      f             - form builder for the parent resource
      compound_name - Symbol, e.g. :contributors
      sub_fields    - Array<String> of every sub-attribute key (the
                      flattened ordered list used by build_permitted_params).
      display_label - String shown as the section heading

    Form params shape:
      <obj>[<compound>_attributes][<index>][<sub_field>]
%>
<% rows = Array(f.object.send(compound_name)) %>
<% form_class = f.object.class %>
<% groups = form_class.const_defined?(:COMPOUND_FIELD_GROUPS) ? form_class::COMPOUND_FIELD_GROUPS.fetch(compound_name, nil) : nil %>
<% groups ||= [{ label: nil, cols: 6, fields: sub_fields }] %>
<% row_label_singular = display_label.to_s.sub(/s\z/, '').presence || display_label.to_s %>
<% compound_id = "#{f.object_name}-#{compound_name}".parameterize %>

<section class="enact-compound mb-4" data-enact-compound data-next-index="<%= rows.length %>" id="<%= compound_id %>">
  <h3 class="h4 mt-4 mb-3"><%= display_label %></h3>

  <%# Always-submitted marker so the populator runs even when the user
      has removed every row from the DOM. The build helper drops the
      `_marker` key. %>
  <%= hidden_field_tag "#{f.object_name}[#{compound_name}_attributes][_marker][_destroy]", '1' %>

  <div data-enact-compound-rows>
    <% rows.each_with_index do |row, index| %>
      <%= render 'hyrax/compounds/compound_row',
                 f: f,
                 compound_name: compound_name,
                 groups: groups,
                 row: row,
                 index: index,
                 row_label_singular: row_label_singular %>
    <% end %>
  </div>

  <p class="mt-2">
    <button type="button" class="btn btn-secondary btn-sm" data-enact-compound-add-row>
      <%= t('enact.compound_fields.add_row', label: row_label_singular) %>
    </button>
  </p>

  <%# Template cloned by JS on Add. __INDEX__ is replaced with a monotonic
      counter held on the wrapper section. The template is rendered with the
      same partial used for live rows, then the placeholder index is stamped
      throughout. %>
  <template data-enact-compound-row-template>
    <%= render 'hyrax/compounds/compound_row',
               f: f,
               compound_name: compound_name,
               groups: groups,
               row: nil,
               index: '__INDEX__',
               row_label_singular: row_label_singular %>
  </template>
</section>
