<%# Renders one compound-attribute section: heading, table of existing rows,
    a <template> for new rows, and an "Add row" button.

    Locals:
      f             - form builder for the parent resource
      compound_name - Symbol, e.g. :contributors
      sub_fields    - Array<String> of sub-attribute keys, e.g. %w[given_name family_name ...]
      display_label - String shown as the section heading

    Form params shape (matches the form's *_attributes populator):
      <obj>[<compound>_attributes][<index>][<sub_field>]
%>
<% rows = Array(f.object.send(compound_name)) %>
<% compound_id = "#{f.object_name}-#{compound_name}".parameterize %>

<section class="enact-compound" data-enact-compound data-next-index="<%= rows.length %>" id="<%= compound_id %>">
  <h3 class="h4 mt-4"><%= display_label %></h3>

  <%# Always-submitted marker so the populator runs even when the user
      has removed every row from the DOM. The build helper filters this
      out by its `_marker` key. %>
  <%= hidden_field_tag "#{f.object_name}[#{compound_name}_attributes][_marker][_destroy]", '1' %>

  <table class="table table-sm">
    <thead>
      <tr>
        <% sub_fields.each do |sub_field| %>
          <th scope="col"><%= t("enact.compound_fields.#{compound_name}.#{sub_field}", default: sub_field.humanize) %></th>
        <% end %>
        <th scope="col" class="sr-only"><%= t('enact.compound_fields.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% rows.each_with_index do |row, index| %>
        <tr data-enact-compound-row>
          <% sub_fields.each do |sub_field| %>
            <% input_id = "#{f.object_name}_#{compound_name}_attributes_#{index}_#{sub_field}" %>
            <% input_name = "#{f.object_name}[#{compound_name}_attributes][#{index}][#{sub_field}]" %>
            <td>
              <%= label_tag input_id,
                            t("enact.compound_fields.#{compound_name}.#{sub_field}", default: sub_field.humanize),
                            class: 'sr-only' %>
              <%= text_field_tag input_name,
                                 row.is_a?(Hash) ? row[sub_field] : nil,
                                 id: input_id,
                                 class: 'form-control form-control-sm' %>
            </td>
          <% end %>
          <td class="text-right" style="width: 1%;">
            <%= hidden_field_tag "#{f.object_name}[#{compound_name}_attributes][#{index}][_destroy]", '0',
                                 id: "#{f.object_name}_#{compound_name}_attributes_#{index}__destroy",
                                 data: { 'enact-compound-destroy-flag': true } %>
            <button type="button"
                    class="btn btn-link"
                    aria-label="<%= t('enact.compound_fields.remove_row') %>"
                    data-enact-compound-remove-row>
              <span aria-hidden="true">&times;</span>
            </button>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p>
    <button type="button" class="btn btn-secondary btn-sm" data-enact-compound-add-row>
      <%= t('enact.compound_fields.add_row', label: display_label) %>
    </button>
  </p>

  <%# Template cloned by JS on Add. The literal __INDEX__ is replaced with
      a monotonic counter held on the wrapper section. %>
  <template data-enact-compound-row-template>
    <tr data-enact-compound-row>
      <% sub_fields.each do |sub_field| %>
        <% input_id = "#{f.object_name}_#{compound_name}_attributes___INDEX___#{sub_field}" %>
        <% input_name = "#{f.object_name}[#{compound_name}_attributes][__INDEX__][#{sub_field}]" %>
        <td>
          <%= label_tag input_id,
                        t("enact.compound_fields.#{compound_name}.#{sub_field}", default: sub_field.humanize),
                        class: 'sr-only' %>
          <%= text_field_tag input_name, nil, id: input_id, class: 'form-control form-control-sm' %>
        </td>
      <% end %>
      <td class="text-right" style="width: 1%;">
        <%= hidden_field_tag "#{f.object_name}[#{compound_name}_attributes][__INDEX__][_destroy]", '0',
                             id: "#{f.object_name}_#{compound_name}_attributes___INDEX____destroy",
                             data: { 'enact-compound-destroy-flag': true } %>
        <button type="button"
                class="btn btn-link"
                aria-label="<%= t('enact.compound_fields.remove_row') %>"
                data-enact-compound-remove-row>
          <span aria-hidden="true">&times;</span>
        </button>
      </td>
    </tr>
  </template>
</section>
