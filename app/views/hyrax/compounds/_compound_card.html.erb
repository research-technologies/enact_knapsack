<%# OVERRIDE Hyrax v5.2.0 hyrax/compounds/_compound_card
    Special-cases the `relationships` compound to render the Enact "related
    within this project" block (outbound edges plus inbound edges found by a
    Solr reverse lookup). Every other card compound falls through to the
    upstream rendering unchanged, so this override stays in sync with upstream
    for non-relationship compounds.

    Locals:
      presenter - a work or collection show presenter
      field     - the compound attribute name (Symbol)
%>
<div class="card hyrax-compound-card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="card-title mb-0"><%= compound_card_label(presenter, field) %></h2>
    <% if field.to_sym == :relationships %>
      <%# Entry point to the interactive relationship map, focused on this work.
          turbo/turbolinks off because the map is a standalone (layout: false) page. %>
      <%= link_to t('enact.relationships.map_button'),
                  "/relationship-map?focus=#{presenter.id}",
                  class: 'btn btn-outline-secondary btn-sm enact-relationship-map-link',
                  data: { turbolinks: false, turbo: false } %>
    <% end %>
  </div>
  <div class="card-body">
    <% if field.to_sym == :relationships %>
      <%# OVERRIDE: Enact patch-cables view (outbound + reverse-lookup inbound). %>
      <%= render 'hyrax/compounds/related_within_project', presenter: presenter %>
    <% else %>
      <%# upstream behavior: render the compound entries via CompoundAttributeRenderer %>
      <%= presenter.attribute_to_html(field.to_sym, render_as: :compound, value_only: true) %>
    <% end %>
  </div>
</div>
