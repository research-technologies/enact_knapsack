<%# Knapsack override of Hyrax 5.2.0 (samvera/hyrax main @ 5cc41d6)
    app/views/hyrax/compounds/_compound_row.html.erb.

    WHY the override: the upstream row renders a label + input but no help
    text, so a compound sub-property whose meaning isn't obvious from its label
    (e.g. relationships `type_other_inverse`) can't be explained inline. This
    copy adds an optional per-sub-property hint sourced from the locale key
    `hyrax.compound_fields.<compound>.<sub>_hint` (blank = no hint), matching the
    muted help text Hyrax already shows under scalar fields. Should be upstreamed
    so the override can be dropped.

    Locals: see upstream (f, compound_name, definition, row, index,
    row_label_singular).
%>
<% subproperties = definition[:subproperties] %>
<% groups = definition[:groups] %>
<% row_value = ->(key) { row.is_a?(Hash) ? (row[key] || row[key.to_sym]) : nil } %>

<div class="card mb-3 hyrax-compound-row" data-hyrax-compound-row role="group" aria-label="<%= row_label_singular %>">
  <div class="card-header bg-light d-flex justify-content-between align-items-center py-2 h6 mb-0">
    <span><%= row_label_singular %></span>
    <button type="button"
            class="close py-0 px-2"
            aria-label="<%= t('hyrax.compound_fields.remove_row_with_label', label: row_label_singular, default: t('hyrax.compound_fields.remove_row')) %>"
            data-hyrax-compound-remove-row>
      <span aria-hidden="true">&times;</span>
    </button>
  </div>
  <div class="card-body">
    <% groups.each do |group| %>
      <% if group[:label].present? %>
        <h4 class="h6 text-muted text-uppercase mt-1 mb-2"><%= group[:label] %></h4>
      <% end %>
      <div class="form-row">
        <% group[:fields].each do |sub_property| %>
          <% spec = subproperties[sub_property] || { type: 'string' } %>
          <% input_id = "#{f.object_name}_#{compound_name}_attributes_#{index}_#{sub_property}" %>
          <% input_name = "#{f.object_name}[#{compound_name}_attributes][#{index}][#{sub_property}]" %>
          <% value = row_value.call(sub_property) %>
          <% hint = t("hyrax.compound_fields.#{compound_name}.#{sub_property}_hint", default: '') %>
          <div class="form-group col-md-<%= spec[:cols] || 6 %>">
            <%= label_tag input_id, class: 'form-label small text-muted' do %>
              <%= compound_subproperty_label(compound_name, sub_property) %><%
                if spec[:required] %><abbr title="<%= t('simple_form.required.text', default: 'required') %>" class="required text-danger">*</abbr><% end %>
            <% end %>
            <% case spec[:type] %>
            <% when 'controlled' %>
              <%= compound_controlled_select(spec, value, input_name, input_id) %>
            <% when 'url' %>
              <%= url_field_tag input_name, value,
                                id: input_id,
                                class: 'form-control form-control-sm' %>
            <% when 'work_or_url' %>
              <%# select2 v3 (bound in compound_metadata.js) binds to this
                  hidden input; `data-label` pre-seeds the displayed text. %>
              <% current_option = compound_work_or_url_option(value) %>
              <%= hidden_field_tag input_name, value,
                                   id: input_id,
                                   class: 'form-control form-control-sm',
                                   data: { 'hyrax-compound-work-input': true,
                                           'label': current_option&.first,
                                           'autocomplete-url': "#{Rails.application.routes.url_helpers.qa_path}/search/compound_works" } %>
            <% when 'linked_record' %>
              <%# A reference to a row in a database table: a select2 picker over
                  the source's QA authority, plus an optional inline create form.
                  See _linked_record_field and Hyrax::CompoundLinkedRecordResolver. %>
              <%= render 'hyrax/compounds/linked_record_field',
                         spec: spec, input_id: input_id, input_name: input_name, value: value %>
            <% when 'datepicker' %>
              <%= date_field_tag input_name, value,
                                 id: input_id,
                                 class: 'datepicker form-control form-control-sm' %>
            <% else %>
              <%# string (default); geocode and other types slot in here later. %>
              <%= text_field_tag input_name, value,
                                 id: input_id,
                                 class: 'form-control form-control-sm' %>
            <% end %>
            <% if hint.present? %>
              <small id="<%= input_id %>_hint" class="form-text text-muted"><%= hint %></small>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= hidden_field_tag "#{f.object_name}[#{compound_name}_attributes][#{index}][_destroy]", '0',
                         id: "#{f.object_name}_#{compound_name}_attributes_#{index}__destroy",
                         data: { 'hyrax-compound-destroy-flag': true } %>
  </div>
</div>
