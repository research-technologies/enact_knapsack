<%# Show-page attribute rows for PortfolioResource. Hyku's non-flexible mode
    overrides Hyrax's view_options_for-driven rendering with a hardcoded list
    per work type (see hyrax-webapp/app/views/hyrax/oers/_attribute_rows.html.erb).
    Mirror that pattern with Enact's Portfolio schema. Compound attributes are
    surfaced via their flattened *_label Solr fields written by the indexer. %>
<% if Hyrax.config.flexible? %>
  <% view_options_for(presenter).each do |field, options| %>
    <% view_options = conform_options(field, options) %>
    <%= presenter.attribute_to_html(conform_field(field, options), view_options) if field_visible?(view_options, presenter) %>
  <% end %>
<% else %>
  <%= presenter.attribute_to_html(:date_modified, label: t('hyrax.base.show.last_modified'), html_dl: true) %>
  <%= presenter.attribute_to_html(:description, html_dl: true) %>
  <%= presenter.attribute_to_html(:context_statement, html_dl: true) %>
  <%= presenter.attribute_to_html(:date_created, render_as: :linked, search_field: 'date_created_tesim', html_dl: true) %>
  <%= presenter.attribute_to_html(:date_made_public, html_dl: true) %>
  <%= presenter.attribute_to_html(:portfolio_date_range, html_dl: true) %>
  <%= presenter.attribute_to_html(:publisher, render_as: :faceted, html_dl: true) %>
  <%= presenter.attribute_to_html(:raid_identifier, html_dl: true) %>
  <%= presenter.attribute_to_html(:keyword, render_as: :faceted, html_dl: true) %>
  <%= presenter.attribute_to_html(:research_group, render_as: :faceted, html_dl: true) %>
  <%= presenter.attribute_to_html(:metadata_rights_statement, html_dl: true) %>
  <%= presenter.attribute_to_html(:file_access_level, render_as: :faceted, html_dl: true) %>
  <%= presenter.attribute_to_html(:ref_unit_of_assessment, render_as: :faceted, html_dl: true) %>
  <%= presenter.attribute_to_html(:contributor_label, html_dl: true, label: t('enact.compound_fields.contributors.section')) %>
  <%= presenter.attribute_to_html(:identifier_value, html_dl: true, label: t('enact.compound_fields.identifiers.section')) %>
  <%= presenter.attribute_to_html(:funder_label, html_dl: true, label: t('enact.compound_fields.funding_references.section')) %>
  <%= presenter.attribute_to_html(:organisational_unit_label, html_dl: true, label: t('enact.compound_fields.organisational_units.section')) %>
  <%= presenter.attribute_to_html(:license_label, html_dl: true, label: t('enact.compound_fields.licenses.section')) %>
<% end %>
